    <style>
        :root {
            --accent: #0047FF; /* Electric Blue */
            --black: #000000;
            --bg: #F8F8F8;
        }

        body {
            font-family: 'Bricolage Grotesque', sans-serif;
            background-color: var(--bg);
            color: var(--black);
            overflow-x: hidden;
        }

        .mono { font-family: 'Space Mono', monospace; }

        /* Neo-Brutalist Border & Shadow */
        .brutal-card {
            background: white;
            border: 2px solid var(--black);
            box-shadow: 8px 8px 0px 0px var(--black);
            transition: all 0.15s ease-in-out;
            position: relative;
        }

        .brutal-card:hover {
            transform: translate(4px, 4px);
            box-shadow: 0px 0px 0px 0px var(--black);
        }

        .brutal-btn {
            background: var(--accent);
            color: white;
            border: 2px solid var(--black);
            box-shadow: 4px 4px 0px 0px var(--black);
            transition: all 0.1s;
            display: inline-block;
            font-weight: 800;
            text-transform: uppercase;
            padding: 1rem 2rem;
            text-align: center;
        }

        .brutal-btn:hover {
            transform: translate(2px, 2px);
            box-shadow: 0px 0px 0px 0px var(--black);
        }

        /* Window Header UI Style */
        .window-header {
            border-bottom: 2px solid black;
            padding: 10px 14px;
            display: flex;
            gap: 8px;
            background: white;
            position: relative;
            z-index: 10;
        }
        .dot { width: 12px; height: 12px; border-radius: 50%; border: 2px solid black; }

        /* Marquee Animation */
        @keyframes marquee {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }
        .animate-marquee {
            animation: marquee 20s linear infinite;
        }

        /* Portrait Image Handling */
        .portrait-container {
            width: 100%;
            aspect-ratio: 3 / 4; /* Perfect Portrait Ratio */
            overflow: hidden;
            display: flex;
        }
        .portrait-container img {
            width: 100%;
            height: 100%;
            object-fit: cover; /* Hides white bits, fills frame */
            object-position: center 20%; /* Focus on face */
        }
    </style>
</head>
